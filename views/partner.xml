<odoo>
    <!-- Button im Formular -->
    <record id="view_partner_form_debtor_button" model="ir.ui.view">
        <field name="name">res.partner.form.debtor.button</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <header>
                    <button name="create_debtor_and_creditor_accounts"
                        string="Debitor/Kreditor-Konten anlegen"
                        type="object" />
                </header>
            </xpath>
        </field>
    </record>
</odoo>